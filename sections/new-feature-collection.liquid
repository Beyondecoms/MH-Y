{%- liquid

  assign collection = collections[section.settings.collection]

  if section.settings.carousel
    assign is_carousel = true
  endif

  assign prod_limit = section.settings.limit
  assign grid = section.settings.grid

  assign enough_to_wrap = true
  if collection.products.size <= grid
    assign enough_to_wrap = false
  endif

  assign section_padding = ''
  if section.settings.section_padding == 'top'
    assign section_padding = 'pb0'
  elsif section.settings.section_padding == 'bottom'
    assign section_padding = 'mt0'
  elsif section.settings.section_padding == 'none'
    assign section_padding = 'mt0 pb0'
  endif

  case grid
    when 2
    assign prod_grid = 50
    when 3
    assign prod_grid = 33.333
    when 4
    assign prod_grid = 25
    when 5
    assign prod_grid = 20
  endcase

  assign aos_mod = section.settings.grid | plus: 0

-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

<section class="fc-section global__section {{ section_padding }}" data-section-id="{{ section.id }}" data-section-type="featured-collection" data-aos="fade">
  <div class="row grid__wrapper gr0">

    {% if section.settings.heading != blank %}
      <div class="span-12 auto fc-heading-wrap">
    <h2 class="section-heading mb0">
          <a href="/collections/new-arrival">BESTSELLER</a>
        </h2>
        <div class="fc-heading-rule"></div>
      </div>
    {% endif %}

    {% capture slideshow_config %}{
      "wrapAround":{{ enough_to_wrap }},
      "cellAlign": "left",
      "dragThreshold":"15",
      "draggable": {{ enough_to_wrap }},
      "pauseAutoPlayOnHover":false,
      "prevNextButtons":{{ enough_to_wrap }},
      "pageDots": false
   }{% endcapture %}

   <div id="featured_collection--{{ section.id }}" class="featured__collection{% if is_carousel %}-carousel flickity__section js-carousel{% endif %} product-loop span-12 auto"{% if is_carousel %} data-flickity-config='{{ slideshow_config }}'{% endif %} data-product-count="{{ collection.products.size }}">
     {% if section.settings.collection == blank %}
      {% render 'onboard-product', prod_limit: prod_limit, grid: grid, aos_mod: aos_mod %}
     {% else %}
       {% for product in collection.products limit: prod_limit %}
         <div class="featured__collection-product product-index js-product-listing"
          id="product-listing-{{ product.id }}"
          data-product-id="{{ product.id }}"
          data-alpha="{{ product.title }}"
          data-price="{{ product.price }}"
          data-aos="fade"
          data-aos-delay="{{ forloop.index | minus: 1 | modulo: aos_mod | times: 100 }}">
           {% liquid

            assign loading = 'lazy'
            assign fetch_priority = 'auto'

            if section.index == 1
              if is_carousel
                if forloop.index <= grid
                  assign loading = 'eager'
                  assign fetch_priority = 'high'
                endif
              else
                assign loading = 'eager'
              endif
            endif

           %}
           {% render 'product-listing-2', product: product, collection: collection, loading: loading, fetchpriority: fetch_priority, index: forloop.index %}
         </div>
       {% endfor %}
     {% endif %}
   </div>

   {% if section.settings.show_view_all %}
    <div class="featured__collection-button-container fc-viewall-wrap span-12 auto">
      <a class="fc-viewall-btn" href="{{ collection.url }}">
        <span>{{ 'sections.featured_collection.view_all' | t }}</span>
        <svg width="16" height="10" viewBox="0 0 16 10" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 5H15M11 1L15 5L11 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
   {% endif %}
  </div>

  <style>
    /* ── Premium Featured Collection – Section Styles ── */
    :root {
      --fc-font-display: 'Cormorant Garamond', Georgia, serif;
      --fc-font-body: 'Jost', sans-serif;
      --fc-color-ink: #1a1a1a;
      --fc-color-muted: #888;
      --fc-color-rule: #d4c9b8;
      --fc-color-accent: #1a1a1a;
      --fc-color-sale: #b5432a;
      --fc-color-badge-bg: rgba(255,255,255,0.92);
      --fc-transition: 0.38s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .fc-section {
      padding-top: 0px;
      padding-bottom: 10px;
      margin-top: 0;
    }

    .fc-heading-wrap {
      text-align: center;
      margin-bottom: 5px;
    }

    .fc-section-heading {
      font-family: var(--fc-font-display);
      font-weight: 400;
      font-size: clamp(1.5rem, 2.5vw, 2rem);
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--fc-color-ink);
      margin: 0 0 14px;
    }

    .fc-section-heading a {
      color: inherit;
      text-decoration: none;
    }

    .fc-heading-rule {
      width: 40px;
      height: 1px;
      background: var(--fc-color-rule);
      margin: 0 auto;
    }

    /* ── View All Button ── */
    .fc-viewall-wrap {
      text-align: center;
      margin-top: 48px;
    }

    .fc-viewall-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--fc-font-body);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--fc-color-ink);
      text-decoration: none;
      border-bottom: 1px solid var(--fc-color-ink);
      padding-bottom: 3px;
      transition: opacity var(--fc-transition);
    }

    .fc-viewall-btn:hover {
      opacity: 0.55;
    }

    /* ── Grid / Carousel ── */
    {% if section.settings.reduce_width %}
      @media screen and (min-width: 741px) {
        #featured_collection--{{ section.id }} {
          width: 88%;
          margin-left: auto;
          margin-right: auto;
        }
      }
    {% endif %}

    {% if is_carousel %}
      #featured_collection--{{ section.id }}.featured__collection-carousel .featured__collection-product {
        width: {{ prod_grid }}%;
        padding: 0 10px;
      }
    {% else %}
      #featured_collection--{{ section.id }}.featured__collection {
        display: grid;
        grid-template-columns: repeat({{ grid }}, 1fr);
        gap: 24px 20px;
      }
      @media screen and (max-width: 740px) {
        #featured_collection--{{ section.id }}.featured__collection {
          grid-template-columns: repeat(2, 1fr);
          gap: 16px 12px;
        }
      }
    {% endif %}
  </style>
</section>
<div class="clear"></div>

{% schema %}
{
  "name": "Featured collection 2",
  "settings": [{
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured collection"
    },
    {
      "id": "collection",
      "type": "collection",
      "label": "Collection"
    },
    {
      "id": "carousel",
      "type": "checkbox",
      "label": "Display in carousel"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button"
    },
    {
      "type": "checkbox",
      "id": "reduce_width",
      "label": "Reduce section width",
      "info": "88% width on non mobile devices"
    },
    {
      "type": "range",
      "id": "grid",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Product grid",
      "default": 4
    },
    {
      "type": "range",
      "id": "limit",
      "min": 2,
      "max": 20,
      "step": 1,
      "label": "Products shown",
      "default": 12
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "Section spacing",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        },
        {
          "value": "both",
          "label": "Both"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "both"
    }
  ],
  "presets": [{
    "name": "Featured collection 2"
  }],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
