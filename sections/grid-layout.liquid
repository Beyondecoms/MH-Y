
<style>
  @media only screen and (max-width: 600px) {
    .mm_grid_2.mm_grid {
    display: flex;
    gap: 10px;
    flex-direction: row;
    flex: auto;
}
    .mob_hide {
   display:none;
    }
    .desk_hide {
   display:block;
    }
    .mm_container {
    max-width: 100%!important;
   }
  }
  .desk_hide {
   display:none;
 }
    .mob_hide {
   display:block;
    }
  .mm_grid {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
  }
  .mm_container {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    max-width: 80%;
    margin: 0 auto;
  }
  .mm_item {
    position: relative;
    overflow: hidden;
  }
  .mm_item img {
    width: 100%;
    height: auto;
    display: block;
  }
  .overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    font-size:1.625rem!important;
    font-family:var(--custom-heading-family)!important;
    transform: translate(-50%, -50%);
    color: white;
    font-size: 17px;
    width: 100%;
    /* font-weight: bold; */
    letter-spacing:1px;
    text-align: center;
    padding: 10px 24px;
    border-radius: 5px;
  }
  /* Adjust grid placement */
  .knitwear {
    grid-column: 1 / 2;
    grid-row: 1 / 2;
  }
  .trousers {
    grid-column: 2 / 3;
    grid-row: 1 / 2;
  }
  .suits {
    grid-column: 3 / 4;
    /* Adjust suits to the third column */
    grid-row: 1 / 2;
  }
  .formal-shirts {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
  }
  .polos {
    grid-column: 2 / 3;
    grid-row: 2 / 3;
  }
  .loafers {
    grid-column: 3 / 4;
    grid-row: 2 / 3;
  }
  .mm_image_blank {
    display: block;
  }
  .mm_image_blank .mm_item {
    aspect-ratio: 2 / 4.365; 
    width: 100%;
    overflow: hidden;
  }
  .mm_image_blank img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
        @media screen and (min-width: 741px) {
        #featured_collection--{{ section.id }} {
          max-width: 73%;
          margin-left: auto;
          margin-right: auto;
        }
      }
  @media only screen and (max-width: 600px) {
    #featured_collection--{{ section.id }} {
        max-width: 91% !important;
    }
}
</style>
  <div class="mm_container featured__collection-carousel" id="featured_collection--{{ section.id }}">
    <div class="mm_grid {% if section.settings.img1 == blank or section.settings.img2 == blank %} mm_image_blank {% endif %}">
      {% if section.settings.img1 != blank %}
      <div class="mm_item knitwear">
      <img src="{{ section.settings.img1 | image_url: width: 600 }}" alt="{{ section.settings.text1 | default: 'Knitwear' | escape }} for Men by MH&Y India" loading="lazy" width="{{ section.settings.img1.width }}" height="{{ section.settings.img1.height }}">
      <div class="overlay">{{ section.settings.text1 }}</div>
    </div>
      {% endif %}
      {% if section.settings.img2 != blank %}
    <div class="mm_item formal-shirts">
      <img src="{{ section.settings.img2 | image_url: width: 600 }}" alt="{{ section.settings.text2 | default: 'Formal Shirts' | escape }} for Men by MH&Y India" loading="lazy" width="{{ section.settings.img2.width }}" height="{{ section.settings.img2.height }}">
      <div class="overlay">{{ section.settings.text2 }}</div>
    </div>
      {% endif %}
  </div>
  <div class="mm_grid {% if section.settings.img3 == blank or section.settings.img4 == blank %} mm_image_blank {% endif %}">
    {% if section.settings.img3 != blank %}
    <div class="mm_item trousers">
     <img src="{{ section.settings.img3 | image_url: width: 600 }}" alt="{{ section.settings.text3 | default: 'Trousers' | escape }} for Men by MH&Y India" loading="lazy" width="{{ section.settings.img3.width }}" height="{{ section.settings.img3.height }}">
      <div class="overlay">{{ section.settings.text3 }}</div>
    </div>
    {% endif %}
    {% if section.settings.img4 != blank %}
    <div class="mm_item polos">
      <img src="{{ section.settings.img4 | image_url: width: 600 }}" alt="{{ section.settings.text4 | default: 'Polos' | escape }} for Men by MH&Y India" loading="lazy" width="{{ section.settings.img4.width }}" height="{{ section.settings.img4.height }}">
      <div class="overlay">{{ section.settings.text4 }}</div>
    </div>
    {% endif %}
  </div>
  <div class="mm_grid_2 mm_grid {% if section.settings.img5 == blank or section.settings.img6 == blank %} mm_image_blank {% endif %}">
    {% if section.settings.img5 != blank %}
    <div class="mm_item suits">
   <img src="{{ section.settings.img5 | image_url: width: 600 }}" alt="{{ section.settings.text5 | default: 'Suits' | escape }} for Men by MH&Y India" loading="lazy" width="{{ section.settings.img5.width }}" height="{{ section.settings.img5.height }}">
      <div class="overlay">{{ section.settings.text5 }}</div>
  </div>
    {% endif %}
    {% if section.settings.img6 != blank %}
  <div class="mm_item loafers">
   <img src="{{ section.settings.img6 | image_url: width: 600 }}" alt="{{ section.settings.text6 | default: 'Loafers' | escape }} for Men by MH&Y India" loading="lazy" width="{{ section.settings.img6.width }}" height="{{ section.settings.img6.height }}">
      <div class="overlay">{{ section.settings.text6 }}</div>
  </div>
    {% endif %}
  </div>
  </div>

