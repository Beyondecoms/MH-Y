{% assign locale_selector = false %}
{% assign country_selector = false %}

{% if section.settings.show_country_selector and localization.available_countries.size > 1 %}
  {% assign country_selector = true %}
{% endif %}

{% if section.settings.show_locale_selector and shop.published_locales.size > 1 %}
  {% assign locale_selector = true %}
{% endif %}

{% assign brand_block = blank %}
{% assign quick_links_block = blank %}

{% for block in section.blocks %}
  {% if block.type == 'text' and brand_block == blank %}
    {% assign brand_block = block %}
  {% endif %}
  {% if block.type == 'menu' and quick_links_block == blank %}
    {% assign quick_links_block = block %}
  {% endif %}
{% endfor %}

{% assign quick_links_menu_handle = section.settings.quick_links_menu %}
{% assign quick_links_heading = section.settings.quick_links_heading | default: 'Quick Links' %}

{% if quick_links_block != blank %}
  {% assign quick_links_heading = quick_links_block.settings.heading | default: quick_links_heading %}
  {% if quick_links_block.settings.footer_nav != blank %}
    {% assign quick_links_menu_handle = quick_links_block.settings.footer_nav %}
  {% endif %}
{% endif %}

{% assign has_facebook = false %}
{% assign has_linkedin = false %}
{% assign has_instagram = false %}

{% if settings.facebook_url != blank %}
  {% assign has_facebook = true %}
{% endif %}

{% if settings.linkedin_url != blank %}
  {% assign has_linkedin = true %}
{% endif %}

{% if settings.instagram_id != blank %}
  {% assign has_instagram = true %}
{% endif %}

{% assign show_connect = section.settings.show_connect %}
{% if has_facebook == false and has_linkedin == false and has_instagram == false %}
  {% assign show_connect = false %}
{% endif %}

{% assign show_support = section.settings.show_support %}
{% assign payment_strip_alt_text = section.settings.payment_strip_alt | default: 'Secure payment methods: UPI, Visa, Mastercard, RuPay, Razorpay' %}

<div class="footer-section mhy-footer-section" data-section-id="{{ section.id }}" data-section-type="footer-section">
  <footer id="footer" class="footer mhy-footer" role="contentinfo">
    <div class="mhy-footer__container">
      <div class="mhy-footer__top">
        {% if brand_block != blank %}
          <div class="mhy-footer__col mhy-footer__brand" {{ brand_block.shopify_attributes }}>
            {% if brand_block.settings.img != blank %}
              <a class="mhy-footer__logo-link" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
                {{
                  brand_block.settings.img
                  | image_url: width: 360
                  | image_tag:
                    class: 'mhy-footer__logo',
                    loading: 'lazy',
                    width: 360,
                    height: 360 | times: brand_block.settings.img.height | divided_by: brand_block.settings.img.width,
                    alt: 'MH&Y India Premium Menswear Logo'
                }}
              </a>
            {% endif %}

            {% if brand_block.settings.footer_text != blank %}
              <div class="mhy-footer__brand-text rte">
                {{ brand_block.settings.footer_text }}
              </div>
            {% endif %}
          </div>
        {% endif %}

        <nav class="mhy-footer__col mhy-footer__links" aria-label="Quick links">
          <h3 class="mhy-footer__title">{{ quick_links_heading | escape }}</h3>
          <ul class="mhy-footer__list" role="list">
            {% if quick_links_menu_handle != blank %}
              {% for link in linklists[quick_links_menu_handle].links %}
                <li class="mhy-footer__item">
                  <a class="mhy-footer__link" href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {% endfor %}
            {% endif %}
          </ul>
        </nav>

        {% if show_support %}
          <div class="mhy-footer__col mhy-footer__support">
            <h3 class="mhy-footer__title">{{ section.settings.support_heading | escape }}</h3>
            <ul class="mhy-footer__meta" role="list">
              {% if section.settings.support_phone != blank %}
                <li class="mhy-footer__meta-item">
                  <a class="mhy-footer__link" href="tel:{{ section.settings.support_phone | remove: ' ' | remove: '-' }}">
                    {{ section.settings.support_phone }}
                  </a>
                </li>
              {% endif %}

              {% if section.settings.support_email != blank %}
                <li class="mhy-footer__meta-item">
                  <a class="mhy-footer__link" href="mailto:{{ section.settings.support_email }}">
                    {{ section.settings.support_email }}
                  </a>
                </li>
              {% endif %}

              {% if section.settings.support_hours != blank %}
                <li class="mhy-footer__meta-item">
                  <span class="mhy-footer__muted">{{ section.settings.support_hours }}</span>
                </li>
              {% endif %}
            </ul>
          </div>
        {% endif %}

        {% if show_connect %}
          <div class="mhy-footer__col mhy-footer__connect">
            <h3 class="mhy-footer__title">{{ section.settings.connect_heading | escape }}</h3>
            <ul class="mhy-footer__social" role="list">
              {% if has_instagram %}
                <li class="mhy-footer__social-item">
                  <a class="mhy-footer__social-link" href="{{ settings.instagram_id }}" target="_blank" rel="noopener" aria-label="MH&Y India on Instagram">
                    {% render 'snip-icons', wrapper: '.mhy-footer__social-link', type: 'social', icon: 'instagram', classes: 'mhy-footer__social-icon', size: '16px', fill: 'var(--footer-color)', hover: 'var(--footer-color)' %}
                  </a>
                </li>
              {% endif %}

              {% if has_facebook %}
                <li class="mhy-footer__social-item">
                  <a class="mhy-footer__social-link" href="{{ settings.facebook_url }}" target="_blank" rel="noopener" aria-label="MH&Y India on Facebook">
                    {% render 'snip-icons', wrapper: '.mhy-footer__social-link', type: 'social', icon: 'facebook', classes: 'mhy-footer__social-icon', size: '16px', fill: 'var(--footer-color)', hover: 'var(--footer-color)' %}
                  </a>
                </li>
              {% endif %}

              {% if has_linkedin %}
                <li class="mhy-footer__social-item">
                  <a class="mhy-footer__social-link" href="{{ settings.linkedin_url }}" target="_blank" rel="noopener" aria-label="MH&Y India on LinkedIn">
                    {% render 'snip-icons', wrapper: '.mhy-footer__social-link', type: 'social', icon: 'linkedin', classes: 'mhy-footer__social-icon', size: '16px', fill: 'var(--footer-color)', hover: 'var(--footer-color)' %}
                  </a>
                </li>
              {% endif %}
            </ul>
          </div>
        {% endif %}
      </div>

      <div class="mhy-footer__divider" aria-hidden="true"></div>

      <div class="mhy-footer__lower">
        <div class="mhy-footer__lower-left">
          {% if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop %}
            <div class="footer__follow-on-shop">
              {{ shop | login_button: action: 'follow' }}
            </div>
          {% endif %}
        </div>

        <div class="mhy-footer__lower-right">
          {% if locale_selector or country_selector %}
            <div class="mhy-footer__selectors disclosures">
              {% if locale_selector %}
                <div class="selectors-form__item">
                  <h2 class="visually-hidden" id="lang-heading">{{ 'general.language.dropdown_label' | t }}</h2>

                  <noscript>
                    {% form 'localization', id: 'FooterLanguageFormNoScript', class: 'selectors-form', data-disclosure-form: '' %}
                      <select name="locale_code" class="localization-selector button disclosure__toggle styled-select" aria-labelledby="lang-heading">
                        <option value="" disabled>{{ 'general.language.dropdown_label' | t }}</option>
                        {% for language in localization.available_languages %}
                          <option value="{{ language.iso_code }}" lang="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                            {{ language.endonym_name | capitalize }}
                          </option>
                        {% endfor %}
                      </select>
                      <button class="localization-form__noscript-btn button disclosure__toggle">
                        {% render 'snip-icons', wrapper: '.section-top-bar__lang', type: 'apollo', icon: 'checkmark', size: '12px', fill: 'var(--topbar-text-color)', hover: 'var(--topbar-background-color)' %}
                      </button>
                    {% endform %}
                  </noscript>

                  {% form 'localization', id: 'FooterLanguageForm', class: 'selectors-form', data-disclosure-form: '' %}
                    <div class="disclosure" data-disclosure-locale>
                      <button type="button" class="disclosure__toggle" aria-expanded="false" aria-controls="lang-list" aria-describedby="lang-heading" data-disclosure-toggle>
                        {{ form.current_locale.endonym_name }}
                      </button>

                      <ul id="lang-list" class="disclosure-list" data-disclosure-list>
                        {% for locale in form.available_locales %}
                          <li class="disclosure-list__item {% if locale.iso_code == form.current_locale.iso_code %}disclosure-list__item--current{% endif %}">
                            <a class="disclosure-list__option" href="#" lang="{{ locale.iso_code }}" {% if locale.iso_code == form.current_locale.iso_code %}aria-current="true"{% endif %} data-value="{{ locale.iso_code }}" data-disclosure-option>
                              {{ locale.endonym_name }}
                            </a>
                          </li>
                        {% endfor %}
                      </ul>

                      <input type="hidden" name="locale_code" id="LocaleSelector" value="{{ form.current_locale.iso_code }}" data-disclosure-input>
                    </div>
                  {% endform %}
                </div>
              {% endif %}

              {% if country_selector %}
                <div class="selectors-form__item">
                  <h2 class="visually-hidden" id="currency-heading_footer">{{ 'general.currency.dropdown_label' | t }}</h2>

                  <noscript>
                    {% form 'localization', id: 'FooterCountryFormNoScript', class: 'selectors-form', data-disclosure-form: '' %}
                      <select class="localization-selector link disclosure__toggle button styled-select" name="country_code" aria-labelledby="currency-heading_footer">
                        <option value="" disabled>{{ 'general.currency.dropdown_label' | t }}</option>
                        {% for country in localization.available_countries %}
                          <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                            {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                          </option>
                        {% endfor %}
                      </select>
                      <button class="localization-form__noscript-btn disclosure__toggle button">
                        {% render 'snip-icons', wrapper: '.section-top-bar__lang', type: 'apollo', icon: 'checkmark', size: '12px', fill: 'var(--topbar-text-color)', hover: 'var(--topbar-background-color)' %}
                      </button>
                    {% endform %}
                  </noscript>

                  {% form 'localization', id: 'FooterCountryForm', class: 'selectors-form', data-disclosure-form: '' %}
                    <div class="disclosure" data-disclosure-currency>
                      <button type="button" class="disclosure__toggle" aria-expanded="false" aria-controls="currency-list_footer" aria-describedby="currency-heading_footer" data-disclosure-toggle>
                        {% if section.settings.show_flag %}
                          <span class="country--flag">
                            {{
                              localization.country
                              | image_url: width: 32
                              | image_tag:
                                class: 'disclosure__toggle__flag',
                                loading: 'lazy',
                                width: 32,
                                height: 32,
                                alt: localization.country.name
                            }}
                          </span>
                        {% endif %}
                        {{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}
                      </button>

                      <ul id="currency-list_footer" class="disclosure-list" data-disclosure-list>
                        {% for country in localization.available_countries %}
                          <li class="disclosure-list__item {% if country.iso_code == localization.country.iso_code %}disclosure-list__item--current{% endif %}">
                            <a class="disclosure-list__option" href="#" {% if country.iso_code == localization.country.iso_code %}aria-current="true"{% endif %} data-value="{{ country.iso_code }}" data-disclosure-option>
                              {% if section.settings.show_flag %}
                                <span class="country--flag">
                                  {{
                                    country
                                    | image_url: width: 32
                                    | image_tag:
                                      class: 'disclosure__toggle__flag',
                                      loading: 'lazy',
                                      width: 32,
                                      height: 32,
                                      alt: country.name
                                  }}
                                </span>
                              {% endif %}
                              <span class="country--name">{{ country.name }}</span>
                              <span class="localization-form__currency">({{ country.currency.iso_code }} {{ country.currency.symbol }})</span>
                            </a>
                          </li>
                        {% endfor %}
                      </ul>

                      <input type="hidden" name="country_code" id="FooterCurrencySelector" value="{{ localization.country.iso_code }}" data-disclosure-input>
                    </div>
                  {% endform %}
                </div>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="mhy-footer__bottom">
      {% if section.settings.show_payment_strip and section.settings.payment_strip != blank %}
        <div class="mhy-footer__payments" aria-label="Secure payment methods">
          {{
            section.settings.payment_strip
            | image_url: width: 1400
            | image_tag:
              class: 'mhy-footer__payment-strip',
              loading: 'lazy',
              width: 1400,
              height: 1400 | times: section.settings.payment_strip.height | divided_by: section.settings.payment_strip.width,
              alt: payment_strip_alt_text
          }}
        </div>
      {% elsif section.settings.show_credit_cards %}
        <div class="mhy-footer__payments" aria-label="Secure payment methods">
          <div class="payment-methods">
            {% for type in shop.enabled_payment_types %}
              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
            {% endfor %}
          </div>
        </div>
      {% endif %}

      <div class="mhy-footer__bottom-bar">
        {% if section.settings.show_copyright %}
          <p class="mhy-footer__copyright">
            <a class="mhy-footer__link" href="{{ routes.root_url }}">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}</a>
          </p>
        {% endif %}
      </div>
    </div>

    <style>
      .mhy-footer {
        background: var(--footer-background);
        color: var(--footer-color);
      }

      .mhy-footer__container {
        margin: 0 auto;
        padding: 64px 50px 28px;
        max-width: 1200px;
      }

      .mhy-footer__top {
        display: grid;
        grid-template-columns: minmax(240px, 1.2fr) minmax(200px, 1fr) minmax(200px, 1fr) minmax(200px, 0.9fr);
        gap: 48px;
        align-items: start;
      }

      .mhy-footer__title {
        margin: 0 0 16px;
        font-family: var(--custom-heading-family);
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--footer-color);
        opacity: 0.9;
      }

      .mhy-footer__brand-text {
        margin-top: 14px;
        opacity: 0.85;
      }

      .mhy-footer__logo {
        display: block;
        height: auto;
        width: 160px;
      }

      .mhy-footer__logo-link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
      }

      .mhy-footer__list,
      .mhy-footer__meta,
      .mhy-footer__social {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 10px;
      }

      .mhy-footer__link {
        color: var(--footer-color);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        opacity: 0.88;
        transition: opacity 160ms ease, transform 160ms ease;
      }

      .mhy-footer__link:hover {
        opacity: 1;
        transform: translateY(-1px);
      }

      .mhy-footer__link:focus-visible {
        outline: var(--keyboard-focus-border-weight) var(--keyboard-focus-border-style) var(--keyboard-focus-color);
        outline-offset: 3px;
        border-radius: 6px;
      }

      .mhy-footer__muted {
        opacity: 0.8;
      }

      .mhy-footer__divider {
        margin: 36px 0 0;
        border-top: 1px solid var(--footer-border);
        opacity: 0.6;
      }

      .mhy-footer__lower {
        margin-top: 18px;
        display: flex;
        gap: 16px;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
      }

      .mhy-footer__selectors {
        display: flex;
        gap: 12px;
        align-items: center;
        justify-content: flex-end;
        flex-wrap: wrap;
      }

      .mhy-footer__social {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .mhy-footer__social-link {
        width: 40px;
        height: 40px;
        border: 1px solid var(--footer-border);
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
        background: rgba(255, 255, 255, 0);
      }

      .mhy-footer__social-link:hover {
        transform: translateY(-2px);
        border-color: var(--footer-color);
        background: rgba(255, 255, 255, 0.06);
      }

      .mhy-footer__social-link:focus-visible {
        outline: var(--keyboard-focus-border-weight) var(--keyboard-focus-border-style) var(--keyboard-focus-color);
        outline-offset: 3px;
      }

      .mhy-footer__bottom {
        border-top: 1px solid var(--footer-border);
        margin-top: 0;
      }

      .mhy-footer__payments {
        max-width: 1200px;
        margin: 0 auto;
        padding: 18px 50px 0;
        display: flex;
        justify-content: center;
      }

      .mhy-footer__payment-strip {
        width: 100%;
        max-width: 560px;
        height: auto;
        opacity: 0.95;
      }

      .payment-methods {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 10px;
      }

      .payment-icon {
        height: 24px;
        width: auto;
        fill: currentColor;
        opacity: 0.9;
      }

      .mhy-footer__bottom-bar {
        max-width: 1200px;
        margin: 0 auto;
        padding: 14px 50px 26px;
        display: flex;
        justify-content: center;
        text-align: center;
      }

      .mhy-footer__copyright {
        margin: 0;
        font-size: 12px;
        letter-spacing: 0.04em;
        opacity: 0.85;
      }

      @media (max-width: 980px) {
        .mhy-footer__top {
          grid-template-columns: 1.2fr 1fr;
          gap: 32px;
        }
      }

      @media (max-width: 740px) {
        .mhy-footer__container {
          padding: 44px 20px 22px;
        }

        .mhy-footer__top {
          grid-template-columns: 1fr;
          gap: 28px;
        }

        .mhy-footer__lower {
          justify-content: flex-start;
        }

        .mhy-footer__selectors {
          justify-content: flex-start;
        }

        .mhy-footer__payments {
          padding: 16px 20px 0;
        }

        .mhy-footer__bottom-bar {
          padding: 12px 20px 22px;
        }
      }
    </style>
  </footer>
</div>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "select",
      "id": "footer_text_align",
      "label": "Footer text align",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "footer_title_transform",
      "label": "Footer title case",
      "options": [
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "inherit",
          "label": "Regular"
        }
      ]
    },
    {
      "type": "range",
      "id": "footer_title_size",
      "min": 12,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Footer title size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Footer Content"
    },
    {
      "type": "link_list",
      "id": "quick_links_menu",
      "label": "Quick links menu"
    },
    {
      "type": "text",
      "id": "quick_links_heading",
      "label": "Quick links heading",
      "default": "Quick Links"
    },
    {
      "type": "checkbox",
      "id": "show_support",
      "label": "Show customer care",
      "default": true
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Customer care heading",
      "default": "Customer Care"
    },
    {
      "type": "text",
      "id": "support_phone",
      "label": "Customer care phone",
      "default": "+91 9555 263263"
    },
    {
      "type": "text",
      "id": "support_email",
      "label": "Customer care email",
      "default": "contact@mhyindia.com"
    },
    {
      "type": "text",
      "id": "support_hours",
      "label": "Customer care hours",
      "default": "Mon–Fri | 10:00 AM – 06:30 PM (IST)"
    },
    {
      "type": "checkbox",
      "id": "show_connect",
      "label": "Show social links",
      "default": true
    },
    {
      "type": "text",
      "id": "connect_heading",
      "label": "Social heading",
      "default": "Connect With Us"
    },
    {
      "type": "header",
      "content": "Secure Payments"
    },
    {
      "type": "checkbox",
      "id": "show_payment_strip",
      "label": "Show payment strip",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "payment_strip",
      "label": "Payment logos strip image",
      "info": "Upload a single horizontal image containing UPI, Visa, Mastercard, RuPay, and Razorpay."
    },
    {
      "type": "text",
      "id": "payment_strip_alt",
      "label": "Payment strip alt text",
      "default": "Secure payment methods: UPI, Visa, Mastercard, RuPay, Razorpay"
    },
    {
      "type": "checkbox",
      "id": "show_credit_cards",
      "label": "Show payment icons",
      "default": true,
      "info": "The icons that show are determined by your store's payment settings."
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Follow on Shop",
      "info": "Display follow button for your storefront on the Shop app. [Learn more](https://help.shopify.com/en/manual/online-store/themes/customizing-themes/follow-on-shop)"
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "default": true,
      "label": "Enable Follow on Shop"
    },
    {
      "type": "checkbox",
      "id": "show_copyright",
      "label": "Show site name and copyright",
      "default": true
    },
    {
      "type": "header",
      "content": "Language Selector",
      "info": "To add a language, go to your [language settings.](/admin/settings/languages)"
    },
    {
      "type": "checkbox",
      "id": "show_locale_selector",
      "label": "Show language selector",
      "default": true
    },
    {
      "type": "header",
      "content": "Country/Region Selector",
      "info": "To add a country/region, go to your [payment settings.](/admin/settings/payments)"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Enable country/region selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_flag",
      "label": "Show country flags",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "link_list",
          "id": "footer_nav",
          "label": "Choose a menu",
          "info": "This menu won't show dropdown items"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Menu title",
          "default": "Explore"
        }
      ]
    },
    {
      "type": "blog",
      "name": "Blog",
      "limit": 1,
      "settings": [
        {
          "id": "footer_blog",
          "type": "blog",
          "label": "Blog"
        },
        {
          "type": "text",
