{% comment %}
  High Value Combos Section
  - Desktop: 4 columns (or scrollable row if > 4 items enabled)
  - Mobile: 2x2 grid (always 4 visible, matching reference image)
  - Heading above the grid
  - Each card: image + label text overlay at bottom
  - Schema: items count toggle, section padding top/bottom
{% endcomment %}

{%- liquid
  assign items_to_show = section.settings.items_to_show
  assign enable_scroll  = false
  if items_to_show > 4
    assign enable_scroll = true
  endif
-%}

<section
  id="hvc-{{ section.id }}"
  class="hvc-section{% if enable_scroll %} hvc-section--scroll{% endif %}"
  style="
    --hvc-pt: {{ section.settings.padding_top }}px;
    --hvc-pb: {{ section.settings.padding_bottom }}px;
    --hvc-items: {{ items_to_show }};
    --hvc-heading-size: {{ section.settings.heading_size }}px;
    --hvc-label-size: {{ section.settings.label_size }}px;
    --hvc-gap: {{ section.settings.grid_gap }}px;
  "
>
  <div class="hvc-inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="hvc-heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="hvc-track-wrap">
      <div class="hvc-track">
        {%- for block in section.blocks -%}
          {%- if forloop.index > items_to_show -%}{%- break -%}{%- endif -%}
          <a
            class="hvc-card"
            href="{{ block.settings.link | default: '#' }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              <div class="hvc-img-wrap">
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    widths: '400, 600, 800',
                    class: 'hvc-img',
                    alt: block.settings.label | escape
                }}
              </div>
            {%- else -%}
              <div class="hvc-img-wrap hvc-img-placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'hvc-svg-placeholder' }}
              </div>
            {%- endif -%}

            {%- if block.settings.label != blank -%}
              <div class="hvc-label">
                <span>{{ block.settings.label | escape }}</span>
                {%- if block.settings.sublabel != blank -%}
                  <span class="hvc-sublabel">{{ block.settings.sublabel | escape }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </a>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

<style>
/* ─── Root ─────────────────────────────────────────────── */
#hvc-{{ section.id }} {
  padding-top: var(--hvc-pt, 40px);
  padding-bottom: var(--hvc-pb, 40px);
  background: {{ section.settings.bg_color }};
}

/* ─── Inner wrapper ─────────────────────────────────────── */
.hvc-inner {
  max-width: {{ section.settings.section_width }}px;
  margin-inline: auto;
  padding-inline: 16px;
}

/* ─── Heading ───────────────────────────────────────────── */
.hvc-heading {
  text-align: center;
  font-size: var(--hvc-heading-size, 16px);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: {{ section.settings.heading_color }};
  margin: 0 0 14px;
  line-height: 1.3;
}

/* ─── Track wrapper (handles overflow for scroll mode) ──── */
.hvc-track-wrap {
  overflow: hidden; /* default: no scroll */
}
.hvc-section--scroll .hvc-track-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: #ccc transparent;
}
.hvc-section--scroll .hvc-track-wrap::-webkit-scrollbar {
  height: 4px;
}
.hvc-section--scroll .hvc-track-wrap::-webkit-scrollbar-track {
  background: transparent;
}
.hvc-section--scroll .hvc-track-wrap::-webkit-scrollbar-thumb {
  background: #ccc;
  border-radius: 4px;
}

/* ─── Track (grid) ──────────────────────────────────────── */
.hvc-track {
  display: grid;
  gap: var(--hvc-gap, 6px);
  /* Default: 4 equal columns on desktop */
  grid-template-columns: repeat(4, 1fr);
}

/* When scroll is active: fixed-width columns so they overflow */
.hvc-section--scroll .hvc-track {
  grid-template-columns: repeat(var(--hvc-items), minmax(260px, 1fr));
  width: max-content;
  min-width: 100%;
}

/* ─── Card ──────────────────────────────────────────────── */
.hvc-card {
  position: relative;
  display: block;
  overflow: hidden;
  text-decoration: none;
  border-radius: {{ section.settings.card_radius }}px;
  aspect-ratio: {{ section.settings.card_aspect }};
  background: #1a1a1a;
}

.hvc-card:focus-visible {
  outline: 2px solid currentColor;
  outline-offset: 3px;
}

/* ─── Image ─────────────────────────────────────────────── */
.hvc-img-wrap {
  position: absolute;
  inset: 0;
}
.hvc-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.45s ease;
}
.hvc-card:hover .hvc-img {
  transform: scale(1.04);
}
.hvc-img-placeholder {
  background: #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hvc-svg-placeholder {
  width: 60%;
  height: 60%;
  opacity: 0.25;
}

/* ─── Gradient overlay ──────────────────────────────────── */
.hvc-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0,0,0,0.65) 0%,
    rgba(0,0,0,0.18) 45%,
    rgba(0,0,0,0) 100%
  );
  pointer-events: none;
}

/* ─── Label ─────────────────────────────────────────────── */
.hvc-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 2;
  padding: 18px 16px 16px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  color: #fff;
  font-size: var(--hvc-label-size, 20px);
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  line-height: 1.2;
  text-align: center;
}
.hvc-sublabel {
  font-size: calc(var(--hvc-label-size, 20px) * 0.72);
  font-weight: 500;
  letter-spacing: 0.08em;
  opacity: 0.92;
}

/* ─── Mobile: 2×2 grid (matching reference) ─────────────── */
@media (max-width: 749px) {
  .hvc-track,
  .hvc-section--scroll .hvc-track {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    width: auto !important;
    min-width: auto !important;
    gap: var(--hvc-gap, 6px);
  }
  /* On mobile always show first 4 cards */
  .hvc-card:nth-child(n+5) {
    display: none;
  }
  .hvc-section--scroll .hvc-track-wrap {
    overflow: hidden !important;
  }
  .hvc-label {
    font-size: calc(var(--hvc-label-size, 20px) * 0.7);
    padding: 12px 10px 10px;
  }
  .hvc-heading {
    font-size: calc(var(--hvc-heading-size, 16px) * 0.9);
    margin-bottom: 10px;
  }
}
</style>

{% schema %}
{
  "name": "High Value Combos",
  "tag": "section",
  "class": "hvc-section-root",
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HIGH VALUE COMBOS"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size (px)",
      "min": 10,
      "max": 36,
      "step": 1,
      "default": 16
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_width",
      "label": "Max section width (px)",
      "min": 800,
      "max": 1600,
      "step": 20,
      "default": 1400
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "items_to_show",
      "label": "Items to show (desktop)",
      "info": "Showing more than 4 enables horizontal scroll on desktop",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between cards (px)",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "select",
      "id": "card_aspect",
      "label": "Card aspect ratio",
      "options": [
        { "value": "3/4", "label": "3:4 (portrait)" },
        { "value": "4/5", "label": "4:5" },
        { "value": "1/1", "label": "1:1 (square)" },
        { "value": "4/3", "label": "4:3 (landscape)" },
        { "value": "16/9", "label": "16:9 (wide)" }
      ],
      "default": "3/4"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius (px)",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label font size (px)",
      "min": 10,
      "max": 36,
      "step": 1,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "combo_item",
      "name": "Combo Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "CATEGORY NAME"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Sub-label (e.g. 2 AT 999)",
    
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "High Value Combos",
      "blocks": [
        {
          "type": "combo_item",
          "settings": {
            "label": "SHIRTS UNDER",
            "sublabel": "799"
          }
        },
        {
          "type": "combo_item",
          "settings": {
            "label": "CLASSIC POLOS",
            "sublabel": "2 AT 999"
          }
        },
        {
          "type": "combo_item",
          "settings": {
            "label": "SHORTS",
            "sublabel": ""
          }
        },
        {
          "type": "combo_item",
          "settings": {
            "label": "PLUS SIZE",
            "sublabel": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
