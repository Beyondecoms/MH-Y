{%- liquid
  assign show_sale = false
  if product.compare_at_price > product.price
    assign show_sale = true
  endif

  assign discount_percent = 0
  if show_sale and product.compare_at_price > 0
    assign discount_percent = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round
  endif

  assign badge_text = product.metafields.custom.badge_text

  assign size_index = nil
  assign color_index = nil
  for option in product.options_with_values
    assign option_name_downcase = option.name | downcase
    if size_index == nil and option_name_downcase contains 'size'
      assign size_index = forloop.index0
    endif
    if color_index == nil and option_name_downcase contains 'color'
      assign color_index = forloop.index0
    endif
  endfor

  assign requires_size = false
  assign requires_color = false
  if product.has_only_default_variant == false
    if size_index != nil
      assign requires_size = true
    endif
    if color_index != nil
      assign requires_color = true
    endif
  endif

  assign size_guide_file = product.metafields.custom.size_guide.value
  assign size_guide_url = ''
  if size_guide_file != blank and size_guide_file.url != blank
    assign size_guide_url = size_guide_file.url
  endif
-%}

<div class="pc-card" data-pc-card data-pc-requires-size="{{ requires_size }}" data-pc-requires-color="{{ requires_color }}"{% if size_index != nil %} data-pc-size-index="{{ size_index }}"{% endif %}{% if color_index != nil %} data-pc-color-index="{{ color_index }}"{% endif %}>
  <script type="application/json" data-pc-variant-data>
    [
      {%- for v in product.variants -%}
        {%- liquid
          assign v_discount = 0
          if v.compare_at_price > v.price and v.compare_at_price > 0
            assign v_discount = v.compare_at_price | minus: v.price | times: 100.0 | divided_by: v.compare_at_price | round
          endif
        -%}
        {
          "id": {{ v.id | json }},
          "available": {{ v.available | json }},
          "options": {{ v.options | json }},
          "price": {{ v.price | json }},
          "compare_at_price": {{ v.compare_at_price | json }},
          "price_formatted": {{ v.price | money | json }},
          "compare_formatted": {{ v.compare_at_price | money | json }},
          "discount_percent": {{ v_discount | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  </script>
  <div class="pc-image-wrap image_{{ aspect_ratio }} js-product-image">
    {% if product.available and badge_text != blank %}
      <div class="pc-badges">
        <span class="pc-badge pc-badge--sale">{{ badge_text }}</span>
      </div>
    {% elsif product.available and show_sale %}
        {% comment %} <div class="pc-badges">
         <span class="pc-badge pc-badge--sale">{{ discount_percent }}% OFF</span>
        </div> {% endcomment %}
    {% endif %}

    <a href="{{ product.url | within: collection }}" class="pc-image-link" aria-label="{{ product.title | escape }}">
      <div class="reveal pc-image-reveal">
        {%- liquid
          assign image_medias = product.media | where: 'media_type', 'image'
          assign primary_image = product.featured_media
          if primary_image == blank or primary_image.media_type != 'image'
            assign primary_image = image_medias | first
          endif
          assign image_count = image_medias.size

          assign img_width = 1200
          assign sizes = '(min-width: 1601px) 2000px, (min-width: 768px) and (max-width: 1600px) 1200px, (max-width: 767px) 100vw, 900px'
          assign widths = '200, 300, 400, 500, 600, 700, 800, 1000, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000'
        -%}

        {%- if image_count < 1 -%}
          <div class="box-ratio pc-placeholder">
            {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
            {{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- else -%}
          {%- if primary_image != blank -%}
            <div class="pc-carousel" data-pc-carousel{% if image_count > 1 %} data-pc-carousel-interval="2000"{% endif %}>
              {%- liquid
                assign primary_height = img_width | times: primary_image.height | divided_by: primary_image.width
              -%}
              <div class="pc-carousel__slide is-active" data-pc-slide>
                {{ primary_image | image_url: width: img_width | image_tag:
                  alt: primary_image.alt | default: product.title,
                  width: img_width,
                  height: primary_height,
                  loading: loading | default: 'lazy',
                  decoding: 'async',
                  fetchpriority: fetchpriority | default: 'auto',
                  sizes: sizes,
                  widths: widths,
                  class: 'pc-carousel__img' }}
              </div>

              {%- for media in image_medias -%}
                {%- if media.id != primary_image.id -%}
                  {%- liquid
                    assign h = img_width | times: media.height | divided_by: media.width
                  -%}
                  <div class="pc-carousel__slide" data-pc-slide>
                    {{ media | image_url: width: img_width | image_tag:
                      alt: media.alt | default: product.title,
                      width: img_width,
                      height: h,
                      loading: 'lazy',
                      decoding: 'async',
                      fetchpriority: 'low',
                      sizes: sizes,
                      widths: widths,
                      class: 'pc-carousel__img' }}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- else -%}
            {% render 'basic-responsive-image',
              type: product.featured_media,
              width: 1200,
              loading: loading,
              fetchpriority: fetchpriority %}
          {%- endif -%}
        {%- endif -%}
      </div>
    </a>

    {% if product.available %}
      <button
        class="pc-mobile-qv-btn {{ qv_classes }} js-quickview-trigger"
        type="button"
        {{ qv_attr }}
        data-product-url="{{ product.url }}?view=quick"
        aria-label="Quick view">
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true">
          <path d="M1 7C1 7 4 1 9 1C14 1 17 7 17 7C17 7 14 13 9 13C4 13 1 7 1 7Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="7" r="2.2" stroke="currentColor" stroke-width="1.3"/>
        </svg>
      </button>
    {% endif %}
  </div>

  <div class="pc-info product-info">
    <a href="{{ product.url | within: collection }}" class="pc-info-link">
      {% if settings.vendor %}
        <p class="pc-vendor product__vendor">{{ product.vendor }}</p>
      {% endif %}
      <h2 class="pc-title">{{ product.title }}</h2>
    </a>

    <div class="pc-rating-row">
      <span class="pc-rating-star">★</span>
      <span class="pc-rating-value">4.6</span>
      <span class="pc-rating-divider">|</span>
      <span class="pc-rating-count">128 reviews</span>
    </div>

    <div class="pc-price-row">
      {% if product.compare_at_price > product.price %}
        <span class="pc-price pc-price--sale" data-pc-price>{{ product.price | money }}</span>
        <span class="pc-compare-price" data-pc-compare>{{ product.compare_at_price | money }}</span>
        <span class="pc-offer-badge" data-pc-offer>{{ discount_percent }}% OFF</span>
      {% else %}
        <span class="pc-price" data-pc-price>{{ product.price | money }}</span>
        <span class="pc-compare-price" data-pc-compare hidden></span>
        <span class="pc-offer-badge" data-pc-offer hidden></span>
      {% endif %}
    </div>

    {%- if requires_color and color_index != nil -%}
      {%- assign color_option = product.options_with_values[color_index] -%}
      <div class="pc-opt pc-opt--color" data-pc-option data-pc-option-index="{{ color_index }}">
        <div class="pc-opt__head">
          <span class="pc-opt__label">Color:</span>
          <span class="pc-opt__value" data-pc-selected-label>Select color</span>
        </div>
        <div class="pc-opt__values pc-opt__values--swatches" role="list">
          {%- for value in color_option.values -%}
            {%- liquid
              assign swatch_color_name = value | handleize | downcase | append: '.png'
              assign swatch_image_url = swatch_color_name | file_url
              assign css_color = value | split: ' ' | last | downcase
              assign bg_img = ''
              if images[swatch_color_name] != blank
                assign bg_img = 'background-image:url(' | append: swatch_image_url | append: ');'
              endif
              assign bg_color = 'background-color:' | append: css_color | append: ';'
            -%}
            <button
              class="pc-swatch"
              type="button"
              style="{{ bg_color }}{{ bg_img }}"
              data-pc-option-value="{{ value | escape }}"
              aria-label="{{ value | escape }}">
            </button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if requires_size and size_index != nil -%}
      {%- assign size_option = product.options_with_values[size_index] -%}
      <div class="pc-opt pc-opt--size" data-pc-option data-pc-option-index="{{ size_index }}">
        <div class="pc-opt__head">
          <span class="pc-opt__label">Size:</span>
          <span class="pc-opt__value" data-pc-selected-label>Select size</span>
          {%- if size_guide_url != blank -%}
            <button class="pc-size-guide" type="button" data-pc-size-guide data-pc-size-guide-url="{{ size_guide_url }}">Size Guide</button>
          {%- endif -%}
        </div>
        <div class="pc-opt__values pc-opt__values--pills" role="list">
          {%- for value in size_option.values -%}
            <button class="pc-pill" type="button" data-pc-option-value="{{ value | escape }}">{{ value }}</button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

        <div class="pc-validation" data-pc-validation role="alert" aria-live="polite" hidden></div>

    <div class="pc-actions">
      <form class="pc-form" method="post" action="/cart/add" data-hide-errors="true">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-pc-variant-id>
        <input type="hidden" name="quantity" value="1">
        <input class="pc-btn pc-btn--atc js-ajax-submit" type="submit" value="Add to Cart" data-pc-atc disabled>
      </form>
    </div>


  </div>
</div>
